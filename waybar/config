{
    "layer": "top",
    "position": "top",
    "height": 24,
    "margin-top": 0,
    "margin-left": 5,
    "margin-right": 5,
    "spacing": 0,
    "modules-left": [
        "custom/terminal",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/vpn",
        "network",
        "pulseaudio",
        "cpu",
        "memory",
        "battery",
        "tray"
    ],
    "custom/terminal": {
        "format": ">_",
        "tooltip": false,
        "on-click": "rofi -show drun -replace -i -theme ~/.config/rofi/launchers/type-1/style-6.rasi"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{id}",
        "persistent-workspaces": {
            "*": 5
        }
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/vpn.sh",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "on-click": "$HOME/.config/waybar/scripts/vpn.sh copy"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": " {essid} [{signalStrength}%]",
        "format-ethernet": " {ifname}",
        "format-disconnected": " offline",
        "tooltip-format-wifi": "iface: {ifname}\nssid: {essid}\nsignal: {signalStrength}%\nip: {ipaddr}/{cidr}\nfreq: {frequency}GHz",
        "tooltip-format-ethernet": "iface: {ifname}\nip: {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "no connection",
        "interval": 15,
        "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "vol {volume}%",
        "format-muted": "vol mute",
        "format-icons": {
            "default": [
                "",
                ""
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "cpu": {
        "format": "cpu {usage}%",
        "interval": 5,
        "tooltip-format": "cpu: {usage}%\nfreq: {avg_frequency}GHz\nload: {load}",
        "on-click": "ghostty -e btop"
    },
    "memory": {
        "format": "mem {percentage}%",
        "interval": 10,
        "tooltip-format": "ram: {used:0.1f}/{total:0.1f}GiB\nswap: {swapUsed:0.1f}/{swapTotal:0.1f}GiB",
        "on-click": "ghostty -e btop"
    },
    "battery": {
        "format": "bat {capacity}%",
        "format-charging": "bat {capacity}% ↑",
        "format-plugged": "bat {capacity}% ⚡",
        "format-alt": "bat {time}",
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 20
        },
        "tooltip-format": "battery: {capacity}%\n{timeTo}\npower: {power:.1f}W"
    },
    "clock": {
        "format": "{:%H:%M:%S}",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "on-click-right": "mode"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 3
    }
}
