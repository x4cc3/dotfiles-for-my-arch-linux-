{
    "layer": "top",
    "position": "top",
    "height": 24,
    "margin-top": 0,
    "margin-left": 5,
    "margin-right": 5,
    "spacing": 0,
    "modules-left": [
        "custom/terminal",
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/vpn",
        "network",
        "pulseaudio",
        "cpu",
        "memory",
        "battery",
        "tray"
    ],
    "custom/terminal": {
        "format": " ",
        "tooltip": false,
        "on-click": "rofi -show drun -replace -i -theme ~/.config/rofi/launchers/type-1/style-6.rasi"
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{id}",
        "persistent-workspaces": {
            "*": 5
        }
    },
    "custom/vpn": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/vpn.sh",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "on-click": "$HOME/.config/waybar/scripts/vpn.sh copy"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": " {essid}",
        "format-ethernet": " {ifname}",
        "format-disconnected": " DOWN",
        "tooltip-format-wifi": "{ifname} · {essid}\n{signalStrength}% · {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname} · {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "No connection",
        "interval": 15,
        "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " mute",
        "format-icons": {
            "default": [
                "",
                ""
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "cpu": {
        "format": " {}%",
        "interval": 10,
        "tooltip-format": "CPU: {usage}%\n{avg_frequency} GHz",
        "on-click": "ghostty -e btop"
    },
    "memory": {
        "format": " {}%",
        "interval": 15,
        "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} GiB",
        "on-click": "ghostty -e btop"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ],
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 20
        },
        "tooltip-format": "Battery: {capacity}%\n{timeTo}\nPower: {power:.1f}W"
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %d/%m %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "on-click-right": "mode"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 3
    }
}
